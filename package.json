{
  "name": "serrch",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "pnpm exec tsx watch src/server.ts",
    "dev:poll": "pnpm exec tsx src/dev.ts",
    "register-webhook": "pnpm exec tsx src/scripts/register-webhook.ts",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/fireworks": "^0.2.0",
    "@hono/node-server": "^1.14.0",
    "@mendable/firecrawl-js": "^1.15.0",
    "ai": "^4.2.0",
    "dotenv": "^17.4.2",
    "grammy": "^1.35.0",
    "hono": "^4.7.0",
    "mongoose": "^8.12.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
